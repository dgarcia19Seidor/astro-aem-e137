---
import BaseLayout from "../layouts/BaseLayout.astro";
import { exams } from "../data/exams";

const availableExams = exams.filter((exam) => exam.questionCount > 0).length;
---

<BaseLayout
  title="AEM Certification Trainer"
  description="Landing para elegir que examen AEM quieres estudiar o practicar."
>
  <section class="mb-10 rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-2xl shadow-slate-950/30 sm:p-8">
    <p class="mb-3 text-sm uppercase tracking-[0.24em] text-emerald-300/80">
      AEM certification trainer
    </p>
    <div class="grid gap-6 lg:grid-cols-[1.5fr_0.8fr] lg:items-end">
      <div>
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Elige el examen y entra en modo estudio o modo test.
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
          La plataforma queda preparada para trabajar varios examenes AEM desde una
          sola landing.
        </p>
      </div>

      <div class="rounded-2xl border border-emerald-400/20 bg-emerald-500/10 p-5">
        <p class="text-sm text-emerald-100/80">Examenes disponibles ahora</p>
        <p class="mt-2 text-4xl font-semibold text-white">{availableExams}</p>
        <p class="mt-2 text-sm text-slate-300">
          {exams.length} certificados configurados en total.
        </p>
      </div>
    </div>
  </section>

  <section class="grid gap-5 md:grid-cols-2">
    {exams.map((exam) => (
      <article
        class={`rounded-3xl border bg-gradient-to-br ${exam.accentClass} bg-slate-900/65 p-6 shadow-xl shadow-slate-950/20`}
      >
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-300">
              {exam.code}
            </p>
            <h2 class="mt-2 text-2xl font-semibold text-white">
              {exam.title}
            </h2>
          </div>

          <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs uppercase tracking-[0.18em] text-slate-200">
            {exam.level}
          </span>
        </div>

        <p class="mt-4 text-sm leading-6 text-slate-300">
          {exam.description}
        </p>

        <p class="mt-4 text-xs uppercase tracking-[0.18em] text-slate-400">
          {exam.audience}
        </p>

        <div class="mt-6 flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-400">
              Banco cargado
            </p>
            <p class="mt-1 text-lg font-semibold text-white">
              {exam.questionCount} preguntas
            </p>
          </div>

          <a
            class="inline-flex items-center justify-center rounded-xl bg-white px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-emerald-200"
            href={`/exams/${exam.slug}`}
          >
            Abrir examen
          </a>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
