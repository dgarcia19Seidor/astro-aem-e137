---
import BaseLayout from "../layouts/BaseLayout.astro";
import { exams } from "../data/exams";

const availableExams = exams.filter((exam) => exam.questionCount > 0).length;
const allTags = [...new Set(exams.flatMap((exam) => exam.tags))].sort((a, b) =>
  a.localeCompare(b),
);
---

<BaseLayout
  title="AEM Certification Trainer"
  description="Landing para elegir que examen AEM quieres estudiar o practicar."
>
  <section class="mb-10 rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-2xl shadow-slate-950/30 sm:p-8">
    <p class="mb-3 text-sm uppercase tracking-[0.24em] text-emerald-300/80">
      AEM certification trainer
    </p>
    <div class="grid gap-6 lg:grid-cols-[1.5fr_0.8fr] lg:items-end">
      <div>
        <h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-white sm:text-5xl">
          Elige el examen y entra en modo estudio o modo test.
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">
          La plataforma queda preparada para trabajar varios examenes AEM desde una
          sola landing.
        </p>
      </div>

      <div class="rounded-2xl border border-emerald-400/20 bg-emerald-500/10 p-5">
        <p class="text-sm text-emerald-100/80">Examenes disponibles ahora</p>
        <p class="mt-2 text-4xl font-semibold text-white">{availableExams}</p>
        <p class="mt-2 text-sm text-slate-300">
          {exams.length} certificados configurados en total.
        </p>
      </div>
    </div>
  </section>

  <section
    class="mb-8 rounded-3xl border border-white/10 bg-slate-900/60 p-5 shadow-xl shadow-slate-950/20"
    data-exam-filters
  >
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm uppercase tracking-[0.2em] text-slate-400">
          Buscar y filtrar
        </p>
        <h2 class="mt-2 text-2xl font-semibold text-white">
          Encuentra el examen por nombre, código o perfil.
        </h2>
      </div>

      <label class="block w-full max-w-xl">
        <span class="sr-only">Buscar examen</span>
        <input
          class="w-full rounded-2xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white outline-none transition placeholder:text-slate-500 focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-400/20"
          type="search"
          name="search"
          placeholder="Buscar por AEM, architect, assets, CDP..."
          autocomplete="off"
          data-search-input
        />
      </label>
    </div>

    <div class="mt-5 flex flex-wrap gap-2">
      <button
        type="button"
        class="rounded-full border border-emerald-400/40 bg-emerald-400/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-emerald-100 transition hover:border-emerald-300/60 hover:bg-emerald-400/15"
        data-tag-button
        data-tag="all"
        aria-pressed="true"
      >
        Todos
      </button>

      {allTags.map((tag) => (
        <button
          type="button"
          class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-slate-300 transition hover:border-white/20 hover:bg-white/10"
          data-tag-button
          data-tag={tag}
          aria-pressed="false"
        >
          {tag}
        </button>
      ))}
    </div>

    <div class="mt-5 flex flex-wrap items-center justify-between gap-3 border-t border-white/10 pt-4">
      <p class="text-sm text-slate-300">
        <span class="font-semibold text-white" data-results-count>{exams.length}</span>
        resultados
      </p>

      <button
        type="button"
        class="rounded-full border border-white/10 px-4 py-2 text-xs font-medium uppercase tracking-[0.18em] text-slate-300 transition hover:border-white/20 hover:bg-white/5"
        data-clear-filters
      >
        Limpiar filtros
      </button>
    </div>
  </section>

  <section class="grid gap-5 md:grid-cols-2" data-exam-list>
    {exams.map((exam) => (
      <article
        data-exam-card
        data-searchable={`${exam.code} ${exam.title} ${exam.level} ${exam.audience} ${exam.description} ${exam.tags.join(" ")}`.toLowerCase()}
        data-tags={exam.tags.join("|")}
        class={`rounded-3xl border bg-gradient-to-br ${exam.accentClass} bg-slate-900/65 p-6 shadow-xl shadow-slate-950/20`}
      >
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-slate-300">
              {exam.code}
            </p>
            <h2 class="mt-2 text-2xl font-semibold text-white">
              {exam.title}
            </h2>
          </div>

          <span class="rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs uppercase tracking-[0.18em] text-slate-200">
            {exam.level}
          </span>
        </div>

        <p class="mt-4 text-sm leading-6 text-slate-300">
          {exam.description}
        </p>

        <p class="mt-4 text-xs uppercase tracking-[0.18em] text-slate-400">
          {exam.audience}
        </p>

        <div class="mt-4 flex flex-wrap gap-2">
          {exam.tags.map((tag) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-slate-300">
              {tag}
            </span>
          ))}
        </div>

        <div class="mt-6 flex items-center justify-between gap-4 rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-slate-400">
              Banco cargado
            </p>
            <p class="mt-1 text-lg font-semibold text-white">
              {exam.questionCount} preguntas
            </p>
          </div>

          <a
            class="inline-flex items-center justify-center rounded-xl bg-white px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-emerald-200"
            href={`/exams/${exam.slug}`}
          >
            Abrir examen
          </a>
        </div>
      </article>
    ))}
  </section>

  <section
    class="hidden rounded-3xl border border-dashed border-white/10 bg-slate-900/40 px-6 py-10 text-center"
    data-empty-state
  >
    <p class="text-sm uppercase tracking-[0.2em] text-slate-500">Sin resultados</p>
    <h3 class="mt-2 text-2xl font-semibold text-white">
      No hay exámenes que coincidan con esa búsqueda.
    </h3>
    <p class="mt-3 text-sm text-slate-300">
      Prueba con otro texto o elimina alguno de los tags activos.
    </p>
  </section>
</BaseLayout>

<script>
  const searchInput = document.querySelector("[data-search-input]");
  const resultCount = document.querySelector("[data-results-count]");
  const emptyState = document.querySelector("[data-empty-state]");
  const clearButton = document.querySelector("[data-clear-filters]");
  const cards = Array.from(document.querySelectorAll("[data-exam-card]"));
  const tagButtons = Array.from(document.querySelectorAll("[data-tag-button]"));

  let activeTag = "all";

  const updateTagButtons = () => {
    tagButtons.forEach((button) => {
      const isActive = button.dataset.tag === activeTag;
      button.setAttribute("aria-pressed", String(isActive));
      button.classList.toggle("border-emerald-400/40", isActive);
      button.classList.toggle("bg-emerald-400/10", isActive);
      button.classList.toggle("text-emerald-100", isActive);
      button.classList.toggle("border-white/10", !isActive);
      button.classList.toggle("bg-white/5", !isActive);
      button.classList.toggle("text-slate-300", !isActive);
    });
  };

  const applyFilters = () => {
    const query = searchInput instanceof HTMLInputElement
      ? searchInput.value.trim().toLowerCase()
      : "";

    let visibleCount = 0;

    cards.forEach((card) => {
      const searchable = card.getAttribute("data-searchable") ?? "";
      const tags = (card.getAttribute("data-tags") ?? "").split("|");
      const matchesQuery = !query || searchable.includes(query);
      const matchesTag = activeTag === "all" || tags.includes(activeTag);
      const visible = matchesQuery && matchesTag;

      card.classList.toggle("hidden", !visible);
      if (visible) visibleCount += 1;
    });

    if (resultCount) {
      resultCount.textContent = String(visibleCount);
    }

    emptyState?.classList.toggle("hidden", visibleCount !== 0);
  };

  searchInput?.addEventListener("input", applyFilters);

  tagButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activeTag = button.dataset.tag ?? "all";
      updateTagButtons();
      applyFilters();
    });
  });

  clearButton?.addEventListener("click", () => {
    activeTag = "all";
    if (searchInput instanceof HTMLInputElement) {
      searchInput.value = "";
    }
    updateTagButtons();
    applyFilters();
  });

  updateTagButtons();
  applyFilters();
</script>
