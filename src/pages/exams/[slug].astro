---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { exams, type RawQuestion } from "../../data/exams";

type PreparedQuestion = RawQuestion & {
  isMulti: boolean;
  correctValues: string[];
};

export function getStaticPaths() {
  const choosePattern = /\(choose (two|three|four|five)\)/i;

  return exams.map((exam) => ({
    params: { slug: exam.slug },
    props: {
      exam: {
        ...exam,
        questionBank: exam.questionBank.map((question) => {
          const shouldSplit =
            Array.isArray(question.correct) ||
            (choosePattern.test(question.question) &&
              typeof question.correct === "string");

          const correctValues = Array.isArray(question.correct)
            ? question.correct
            : shouldSplit
              ? question.correct.split(/\s*,\s*/).filter(Boolean)
              : [question.correct];

          return {
            ...question,
            isMulti: correctValues.length > 1,
            correctValues,
          };
        }),
      },
    },
  }));
}

const { exam } = Astro.props as {
  exam: (typeof exams)[number] & { questionBank: PreparedQuestion[] };
};

const studyQuestions = exam.questionBank;
const examConfig = {
  code: exam.code,
  sampleSize: exam.sampleSize,
};
---

<BaseLayout
  title={`${exam.code} | AEM Certification Trainer`}
  description={`Estudia ${exam.code} con modo estudio y modo test.`}
>
  <a
    href="/"
    class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-slate-300 transition hover:text-white"
  >
    <span aria-hidden="true">&larr;</span>
    Volver a la seleccion de examenes
  </a>

  <section class="mb-8 rounded-3xl border border-white/10 bg-slate-900/70 p-6 shadow-2xl shadow-slate-950/30 sm:p-8">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-[0.24em] text-emerald-300/80">
          {exam.code}
        </p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          {exam.title}
        </h1>
        <p class="mt-4 text-base leading-7 text-slate-300">
          {exam.description}
        </p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-slate-950/50 px-5 py-4">
        <p class="text-xs uppercase tracking-[0.2em] text-slate-400">
          Preguntas cargadas
        </p>
        <p class="mt-1 text-3xl font-semibold text-white">{exam.questionCount}</p>
        <p class="mt-1 text-sm text-slate-400">
          Muestra sugerida por test: {Math.min(exam.sampleSize, exam.questionCount || exam.sampleSize)}
        </p>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <button
        type="button"
        class="mode-btn inline-flex items-center justify-center rounded-xl bg-emerald-500 px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-emerald-300"
        data-mode-target="study"
      >
        Estudiar preguntas
      </button>
      <button
        type="button"
        class="mode-btn inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:border-emerald-300 hover:text-emerald-200"
        data-mode-target="exam"
      >
        Hacer test
      </button>
    </div>
  </section>

  <section id="study-section" data-mode-section="study" class="space-y-6">
    {studyQuestions.length > 0 ? (
      <>
        <p class="text-sm text-slate-300">
          Marca la respuesta correcta y pulsa <span class="font-semibold text-white">Check</span>.
          Si la pregunta es multi-respuesta podras seleccionar varias opciones.
        </p>

        {studyQuestions.map((question, idx) => (
          <article
            class="rounded-2xl border border-white/10 bg-slate-900/65 p-5 shadow-lg shadow-slate-950/20"
            data-question-index={idx}
          >
            <header class="mb-4 flex items-start gap-3">
              <span class="rounded-lg bg-slate-800 px-2 py-1 text-xs font-medium text-slate-200">
                #{question.id}
              </span>
              <div>
                <h2 class="font-semibold leading-6 text-white">{question.question}</h2>
                {question.isMulti && (
                  <p class="mt-1 text-xs uppercase tracking-[0.18em] text-amber-300">
                    Multi-select
                  </p>
                )}
              </div>
            </header>

            <ul class="space-y-2">
              {question.answers.map((answer) => (
                <li>
                  <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-transparent px-3 py-2 transition hover:border-emerald-400/30 hover:bg-white/5">
                    <input
                      class="mt-1 h-4 w-4 border-white/20 bg-slate-950 text-emerald-400 focus:ring-emerald-400"
                      type={question.isMulti ? "checkbox" : "radio"}
                      name={`study-q-${idx}`}
                      value={answer}
                    />
                    <span class="text-sm leading-6 text-slate-200">{answer}</span>
                  </label>
                </li>
              ))}
            </ul>

            <div class="mt-5 flex flex-wrap items-center justify-between gap-3">
              <div class="flex flex-wrap gap-2">
                <button
                  type="button"
                  class="check-btn inline-flex items-center justify-center rounded-xl bg-emerald-500 px-3 py-2 text-sm font-medium text-slate-950 transition hover:bg-emerald-300"
                  data-correct={JSON.stringify(question.correctValues)}
                >
                  Check
                </button>
                <button
                  type="button"
                  class="reason-btn inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-3 py-2 text-sm font-medium text-white transition hover:border-emerald-300 hover:text-emerald-200"
                >
                  Show reason
                </button>
              </div>

              <span class="result hidden text-sm font-medium"></span>
            </div>

            <p class="reason mt-4 hidden rounded-xl border border-white/10 bg-slate-950/50 p-4 text-sm leading-6 text-slate-300">
              {question.reason}
            </p>
          </article>
        ))}
      </>
    ) : (
      <div class="rounded-2xl border border-amber-400/20 bg-amber-500/10 p-5 text-sm leading-6 text-amber-100">
        Todavia no hay preguntas cargadas para este examen. La ruta ya esta lista y solo falta
        incorporar el banco real.
      </div>
    )}
  </section>

  <section id="exam-section" data-mode-section="exam" class="hidden space-y-6">
    {studyQuestions.length > 0 ? (
      <>
        <div class="rounded-2xl border border-white/10 bg-slate-900/65 p-5 shadow-lg shadow-slate-950/20">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="max-w-2xl">
              <h2 class="text-xl font-semibold text-white">Modo test</h2>
              <p class="mt-2 text-sm leading-6 text-slate-300">
                Genera un test aleatorio sin correccion inmediata. Al final veras nota,
                aciertos y la explicacion de cada pregunta.
              </p>
            </div>

            <button
              type="button"
              id="generate-exam-btn"
              class="inline-flex items-center justify-center rounded-xl bg-white px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-emerald-200"
            >
              Generar test
            </button>
          </div>

          <p id="exam-meta" class="mt-4 text-sm text-slate-400"></p>
        </div>

        <form id="exam-form" class="hidden space-y-6">
          <div id="exam-summary" class="hidden rounded-2xl border border-emerald-400/20 bg-emerald-500/10 p-5"></div>
          <div id="exam-questions" class="space-y-6"></div>
          <div class="flex flex-wrap gap-3">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-xl bg-emerald-500 px-4 py-2 text-sm font-medium text-slate-950 transition hover:bg-emerald-300"
            >
              Corregir test
            </button>
            <button
              type="button"
              id="reset-exam-btn"
              class="inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/5 px-4 py-2 text-sm font-medium text-white transition hover:border-emerald-300 hover:text-emerald-200"
            >
              Nuevo test
            </button>
          </div>
        </form>
      </>
    ) : (
      <div class="rounded-2xl border border-amber-400/20 bg-amber-500/10 p-5 text-sm leading-6 text-amber-100">
        El modo test estara disponible automaticamente cuando se carguen preguntas para este examen.
      </div>
    )}
  </section>

  {studyQuestions.length > 0 && (
    <script define:vars={{ questionsData: studyQuestions, examConfig }}>
      const sortValues = (values) => [...values].map((value) => value.trim()).sort();
      const isSameAnswerSet = (selectedValues, correctValues) => {
        const selected = sortValues(selectedValues);
        const correct = sortValues(correctValues);
        return (
          selected.length === correct.length &&
          selected.every((value, index) => value === correct[index])
        );
      };

      const escapeHtml = (value) =>
        value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");

      const shuffle = (items) => {
        const cloned = [...items];
        for (let index = cloned.length - 1; index > 0; index -= 1) {
          const swapIndex = Math.floor(Math.random() * (index + 1));
          [cloned[index], cloned[swapIndex]] = [cloned[swapIndex], cloned[index]];
        }
        return cloned;
      };

      const setMode = (mode) => {
        document.querySelectorAll("[data-mode-section]").forEach((section) => {
          section.classList.toggle("hidden", section.dataset.modeSection !== mode);
        });

        document.querySelectorAll(".mode-btn").forEach((button) => {
          const isActive = button.dataset.modeTarget === mode;
          button.classList.toggle("bg-emerald-500", isActive);
          button.classList.toggle("text-slate-950", isActive);
          button.classList.toggle("border", !isActive);
          button.classList.toggle("border-white/15", !isActive);
          button.classList.toggle("bg-white/5", !isActive);
          button.classList.toggle("text-white", !isActive);
        });
      };

      document.querySelectorAll(".mode-btn").forEach((button) => {
        button.addEventListener("click", () => setMode(button.dataset.modeTarget));
      });

      document.querySelectorAll("[data-question-index]").forEach((card) => {
        const button = card.querySelector(".check-btn");
        const result = card.querySelector(".result");
        const reasonBtn = card.querySelector(".reason-btn");
        const reasonEl = card.querySelector(".reason");

        if (!button || !result) return;

        button.addEventListener("click", () => {
          const correctValues = JSON.parse(button.dataset.correct || "[]");
          const selectedValues = Array.from(
            card.querySelectorAll("input:checked"),
          ).map((input) => input.value);

          const isCorrect = isSameAnswerSet(selectedValues, correctValues);

          result.classList.remove("hidden", "text-emerald-300", "text-rose-300");
          result.textContent = isCorrect
            ? "Correct"
            : `Incorrect. Correct answer: ${correctValues.join(", ")}`;
          result.classList.add(isCorrect ? "text-emerald-300" : "text-rose-300");
        });

        if (reasonBtn && reasonEl) {
          reasonBtn.addEventListener("click", () => {
            const shouldShow = reasonEl.classList.contains("hidden");
            reasonEl.classList.toggle("hidden", !shouldShow);
            reasonBtn.textContent = shouldShow ? "Hide reason" : "Show reason";
          });
        }
      });

      const generateExamButton = document.querySelector("#generate-exam-btn");
      const examForm = document.querySelector("#exam-form");
      const examQuestions = document.querySelector("#exam-questions");
      const examSummary = document.querySelector("#exam-summary");
      const examMeta = document.querySelector("#exam-meta");
      const resetExamButton = document.querySelector("#reset-exam-btn");

      let activeExam = [];

      const renderExam = () => {
        const sampleSize = Math.min(examConfig.sampleSize, questionsData.length);
        activeExam = shuffle(questionsData).slice(0, sampleSize);

        examMeta.textContent = `${activeExam.length} preguntas generadas para ${examConfig.code}.`;
        examSummary.classList.add("hidden");
        examSummary.innerHTML = "";

        examQuestions.innerHTML = activeExam
          .map(
            (question, index) => `
              <article class="rounded-2xl border border-white/10 bg-slate-900/65 p-5 shadow-lg shadow-slate-950/20" data-exam-question="${index}">
                <header class="mb-4 flex items-start gap-3">
                  <span class="rounded-lg bg-slate-800 px-2 py-1 text-xs font-medium text-slate-200">
                    ${index + 1}
                  </span>
                  <div>
                    <h3 class="font-semibold leading-6 text-white">${escapeHtml(question.question)}</h3>
                    ${question.isMulti ? '<p class="mt-1 text-xs uppercase tracking-[0.18em] text-amber-300">Multi-select</p>' : ""}
                  </div>
                </header>
                <ul class="space-y-2">
                  ${question.answers
                    .map(
                      (answer) => `
                        <li>
                          <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-transparent px-3 py-2 transition hover:border-emerald-400/30 hover:bg-white/5">
                            <input
                              class="mt-1 h-4 w-4 border-white/20 bg-slate-950 text-emerald-400 focus:ring-emerald-400"
                              type="${question.isMulti ? "checkbox" : "radio"}"
                              name="exam-q-${index}"
                              value="${escapeHtml(answer)}"
                            />
                            <span class="text-sm leading-6 text-slate-200">${escapeHtml(answer)}</span>
                          </label>
                        </li>
                      `,
                    )
                    .join("")}
                </ul>
                <div class="exam-result mt-4 hidden rounded-xl border border-white/10 bg-slate-950/50 p-4 text-sm leading-6"></div>
              </article>
            `,
          )
          .join("");

        examForm.classList.remove("hidden");
      };

      generateExamButton?.addEventListener("click", renderExam);
      resetExamButton?.addEventListener("click", renderExam);

      examForm?.addEventListener("submit", (event) => {
        event.preventDefault();

        let score = 0;

        activeExam.forEach((question, index) => {
          const selectedValues = Array.from(
            examForm.querySelectorAll(`[name="exam-q-${index}"]:checked`),
          ).map((input) => input.value);

          const resultElement = examForm.querySelector(
            `[data-exam-question="${index}"] .exam-result`,
          );

          const isCorrect = isSameAnswerSet(selectedValues, question.correctValues);
          if (isCorrect) score += 1;

          resultElement.classList.remove(
            "hidden",
            "border-emerald-400/20",
            "bg-emerald-500/10",
            "text-emerald-100",
            "border-rose-400/20",
            "bg-rose-500/10",
            "text-rose-100",
          );
          resultElement.classList.add(
            isCorrect ? "border-emerald-400/20" : "border-rose-400/20",
            isCorrect ? "bg-emerald-500/10" : "bg-rose-500/10",
            isCorrect ? "text-emerald-100" : "text-rose-100",
          );
          resultElement.innerHTML = `
            <p class="font-medium">${isCorrect ? "Correct" : "Incorrect"}</p>
            <p class="mt-2"><span class="font-medium">Correct answer:</span> ${question.correctValues
              .map(escapeHtml)
              .join(", ")}</p>
            <p class="mt-2 text-slate-200">${escapeHtml(question.reason)}</p>
          `;
        });

        const percentage = Math.round((score / activeExam.length) * 100);
        examSummary.classList.remove("hidden");
        examSummary.innerHTML = `
          <p class="text-sm uppercase tracking-[0.2em] text-emerald-100/80">Resultado</p>
          <p class="mt-2 text-3xl font-semibold text-white">${score}/${activeExam.length}</p>
          <p class="mt-2 text-sm text-slate-200">Puntuacion aproximada: ${percentage}%</p>
        `;
        examSummary.scrollIntoView({ behavior: "smooth", block: "nearest" });
      });
    </script>
  )}
</BaseLayout>
